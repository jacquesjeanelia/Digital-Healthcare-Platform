<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Doctor</title>
    <link rel="stylesheet" href="../style.css">
</head>
<body>
    <header>
        <h1>Edit Doctor</h1>
    </header>

    <section id="edit-doctor-section">
        <h2>Doctor Information</h2>

        <!-- Doctor Name -->
        <p><strong>Name:</strong> <span id="doctorName">Dr. John Smith</span></p>

        <!-- Doctor Field -->
        <p><strong>Field:</strong> <span id="doctorField">General Practitioner</span></p>

        <!-- Update Working Hours -->
        <h3>Update Working Hours</h3>
        <form id="updateWorkingHoursForm">
            <!-- Monday -->
            <div class="day-slot">
                <label for="mondayStart">Monday:</label>
                <input type="time" id="mondayStart" name="mondayStart" required>
                to
                <input type="time" id="mondayEnd" name="mondayEnd" required>
            </div>

            <!-- Tuesday -->
            <div class="day-slot">
                <label for="tuesdayStart">Tuesday:</label>
                <input type="time" id="tuesdayStart" name="tuesdayStart" required>
                to
                <input type="time" id="tuesdayEnd" name="tuesdayEnd" required>
            </div>

            <!-- Wednesday -->
            <div class="day-slot">
                <label for="wednesdayStart">Wednesday:</label>
                <input type="time" id="wednesdayStart" name="wednesdayStart" required>
                to
                <input type="time" id="wednesdayEnd" name="wednesdayEnd" required>
            </div>

            <!-- Thursday -->
            <div class="day-slot">
                <label for="thursdayStart">Thursday:</label>
                <input type="time" id="thursdayStart" name="thursdayStart" required>
                to
                <input type="time" id="thursdayEnd" name="thursdayEnd" required>
            </div>

            <!-- Friday -->
            <div class="day-slot">
                <label for="fridayStart">Friday:</label>
                <input type="time" id="fridayStart" name="fridayStart" required>
                to
                <input type="time" id="fridayEnd" name="fridayEnd" required>
            </div>

            <!-- Saturday -->
            <div class="day-slot">
                <label for="saturdayStart">Saturday:</label>
                <input type="time" id="saturdayStart" name="saturdayStart">
                to
                <input type="time" id="saturdayEnd" name="saturdayEnd">
            </div>

            <!-- Sunday -->
            <div class="day-slot">
                <label for="sundayStart">Sunday:</label>
                <input type="time" id="sundayStart" name="sundayStart">
                to
                <input type="time" id="sundayEnd" name="sundayEnd">
            </div>

            <!-- Save Button -->
            <button class="button save-button" type="submit">Save Changes</button>
        </form>

        <!-- Remove Doctor Section -->
        <h3>Remove Doctor</h3>
        <button class="button remove-button" onclick="goBack()">Remove Doctor</button>

        <!-- Back Button -->
        <button class="button back-button" onclick="goBack()">Back to Main Menu</button>
    </section>

    <!-- JavaScript -->
    <script>
        function goBack() {
            window.history.back(); // Navigate back to the previous page
        }

        function removeDoctor() {
            const doctorName = document.getElementById('doctorName').textContent;
            const confirmation = confirm(`Are you sure you want to remove ${doctorName}?`);
            
            if (confirmation) {
                alert(`${doctorName} has been removed.`);
                // Redirect or perform additional actions here
            }
        }

        document.getElementById('updateWorkingHoursForm').addEventListener('submit', function(event) {
            event.preventDefault(); // Prevent form submission

            const updatedWorkingHours = {
                monday: `${document.getElementById('mondayStart').value} - ${document.getElementById('mondayEnd').value}`,
                tuesday: `${document.getElementById('tuesdayStart').value} - ${document.getElementById('tuesdayEnd').value}`,
                wednesday: `${document.getElementById('wednesdayStart').value} - ${document.getElementById('wednesdayEnd').value}`,
                thursday: `${document.getElementById('thursdayStart').value} - ${document.getElementById('thursdayEnd').value}`,
                friday: `${document.getElementById('fridayStart').value} - ${document.getElementById('fridayEnd').value}`,
                saturday: `${document.getElementById('saturdayStart').value || 'Closed'} - ${document.getElementById('saturdayEnd').value || 'Closed'}`,
                sunday: `${document.getElementById('sundayStart').value || 'Closed'} - ${document.getElementById('sundayEnd').value || 'Closed'}`,
            };

            console.log('Updated Working Hours:', updatedWorkingHours);
            alert('Working hours have been updated successfully!');
        });
    </script>
</body>
</html>
